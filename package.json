{
  "name": "activescott-auth",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic authentication with provider pattern for magic links, OAuth, and more",
  "type": "module",
  "workspaces": [
    "packages/auth",
    "packages/auth-provider-email",
    "packages/auth-adapter-react-router"
