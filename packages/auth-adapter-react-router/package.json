{
  "name": "@activescott/auth-adapter-react-router",
  "version": "0.1.1",
  "description": "React Router adapter for @activescott/auth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "auth",
    "authentication",
    "react-router",
    "remix"
  ],
  "author": "Scott Willeke",
  "license": "MIT",
  "peerDependencies": {
    "@activescott/auth": "*",
    "react-router": "^7.0.0"
  },
  "devDependencies": {
    "@activescott/auth": "*",
    "@types/node": "^22",
    "react-router": "^7.13.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
