{
  "name": "@activescott/auth-provider-email",
  "version": "0.1.2",
  "description": "Email magic link provider for @activescott/auth",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "auth",
    "authentication",
    "magic-link",
    "email",
    "nodemailer"
  ],
  "author": "Scott Willeke",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/activescott/auth.git",
    "directory": "packages/auth-provider-email"
  },
  "dependencies": {
    "nodemailer": "^8.0.4"
  },
  "peerDependencies": {
    "@activescott/auth": "^0.1.1"
  },
  "devDependencies": {
    "@activescott/auth": "*",
    "@types/nodemailer": "^7.0.9",
    "@types/node": "^22",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
